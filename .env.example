# Root ESG pipeline configuration

# Deployment safety
# Use APP_ENV=production or staging in deployed environments. The backend will
# refuse to start there unless JWT_SECRET is strong and non-default.
APP_ENV=development
JWT_SECRET=
# Comma-separated frontend origins. Leave empty for localhost dev defaults.
CORS_ALLOW_ORIGINS=
# Optional regex for temporary tunnel origins, e.g. ngrok/cloudflare during demos.
CORS_ALLOW_ORIGIN_REGEX=https://.*\.ngrok-free\.app|https://.*\.ngrok\.app

# Base model and adapter
ESG_BASE_MODEL_PATH=
ESG_ADAPTER_PATH=
HF_LOCAL_FILES_ONLY=true
ESG_MODEL_ALLOW_DOWNLOAD=false

# Ingestion performance tuning
CHUNK_SIZE=1500
CHUNK_OVERLAP=150
EXTRACTION_CACHE_ENABLED=true
EXTRACTION_CACHE_PATH=./data/extraction_cache.sqlite
# Keep 1 for local QLoRA. Raise to 5-10 only when extraction is remote/API-backed and rate limits allow it.
EXTRACTION_MAX_WORKERS=10
# Concurrent ingestion jobs. Shared writes (active vector manifest, BM25 index, document registry)
# are atomic / lock-protected, so multiple jobs can safely run side by side.
# Lower this to 1 if you want serialized ingestion (e.g. constrained Neo4j Aura tier).
INGESTION_JOB_MAX_WORKERS=4
INGESTION_MAX_QUEUED_JOBS=16
INGESTION_AUDIT_THROTTLE_SECONDS=2.0

# Embedding model
# Default project embedding model: BAAI/bge-m3
# If you downloaded the local ONNX model under ./models/BAAI_bge-m3, this can stay empty.
# If using Pinecone with a 1024-d index, you MUST have bge-m3 available.
# Either:
#   (a) place the model in models/BAAI_bge-m3/ and set ESG_EMBEDDING_LOCAL_FILES_ONLY=true
#   (b) set ESG_EMBEDDING_ALLOW_DOWNLOAD=true (first run may download ~2GB)
ESG_EMBEDDING_MODEL_PATH=
ESG_EMBEDDING_LOCAL_FILES_ONLY=false
ESG_EMBEDDING_ALLOW_DOWNLOAD=false

# Optional OpenAI-backed QA for the root RAG pipeline
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=700
OPENAI_TIMEOUT=60
DESKTOP_SCREENSHOT_SUMMARY_MODEL=gpt-4o-mini
DESKTOP_SCREENSHOT_SUMMARY_MAX_TOKENS=700
DESKTOP_SCREENSHOT_MAX_IMAGE_BYTES=6000000
RAG_ANSWER_MODE=auto
RAG_ALLOW_SPECULATION=false
RAG_MULTI_QUERY_ENABLED=false
RAG_MULTI_QUERY_N=3
RAG_HYBRID_ENABLED=false
RAG_HYBRID_BM25_WEIGHT=0.4
RAG_HYBRID_FUSION=rrf
RAG_RRF_K=60
RAG_RRF_VECTOR_WEIGHT=1.0
RAG_RRF_BM25_WEIGHT=1.0
RAG_RRF_TERM_BOOST=0.01
RAG_RRF_DIVERSITY_PENALTY=0.0
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K_BEFORE=20
RERANKER_TOP_K_AFTER=5
HYDE_ENABLED=false
HYDE_MODEL=gpt-5.4-mini
HYDE_MAX_TOKENS=200
HYDE_MIN_CHARS=50
RAG_DECOMPOSE_ENABLED=false
RAG_DECOMPOSE_MAX_SUBQ=3
RAG_ROUTER_ENABLED=true
RAG_ROUTER_LLM_ENABLED=false
RAG_CHITCHAT_ENABLED=true
RAG_ANSWER_INTENT_ROUTER_ENABLED=true
RAG_RATE_LIMIT_ENABLED=true
RAG_FREE_DAILY_POINTS=30
RAG_FLASH_POINT_COST=1
RAG_DEEP_POINT_COST=5
RAG_MIN_SECONDS_BETWEEN_REQUESTS=20
RAG_ANONYMOUS_ENABLED=false

# Agent reasoning-tier (Flash / Deep). Flash = OpenAI quick path; Deep = Claude
# with deeper retrieval. Without ANTHROPIC_API_KEY, Deep gracefully falls back
# to Flash.
RAG_FLASH_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
RAG_DEEP_MODEL=claude-opus-4-7
RAG_DEEP_MAX_TOKENS=2000
RAG_DEEP_TEMPERATURE=0.2
RAG_DEEP_TIMEOUT=90

# HITL notifications (opt-in)
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_DB_PATH=backend/notifications.db
NOTIFICATIONS_DEDUP_WINDOW_MINUTES=60
NOTIFICATIONS_DAILY_EMAIL_CAP=8
NOTIFICATIONS_SMTP_URL=
NOTIFICATIONS_ADMIN_EMAILS=

# Backend platform mock mode. Set to false to actually call OpenAI when OPENAI_API_KEY is present.
MOCK_MODE=false

# Redis (used by short-term memory; reserved for future cross-worker invalidation / query result caching).
# Leave REDIS_ENABLED=false to skip all Redis access.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Workflow-node tracing. JSONL written to TRACE_PATH; tail with `tail -f data/traces.jsonl | jq .`.
TRACE_ENABLED=false
TRACE_PATH=./data/traces.jsonl

# Structured ESG metric extraction. When enabled, every uploaded document also runs the
# metric extractor and writes rows to ESG_METRICS_DB_PATH. Adds 1 LLM call per chunk;
# leave off until you've reviewed the taxonomy and prompt.
ESG_METRICS_EXTRACTION_ENABLED=false
ESG_METRICS_DB_PATH=./data/esg_metrics.sqlite
ESG_METRICS_TAXONOMY_PATH=./data/taxonomy/esg_metrics.yaml
ESG_METRICS_MIN_CONFIDENCE=0.5

# Optional DeepSeek-backed extraction fallback when the local QLoRA model is unavailable
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_EXTRACTION_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=60
DEEPSEEK_EXTRACTION_MAX_TOKENS=8000
RAG_ANSWER_INTENT_ROUTER_MODEL=deepseek-v4-flash
RAG_ANSWER_INTENT_ROUTER_TIMEOUT=2
RAG_ANSWER_INTENT_ROUTER_MAX_TOKENS=240

# Optional comma-separated admin allowlist for /admin.
# If empty, admin APIs are only available from direct localhost requests after login.
ADMIN_EMAILS=

# Registration email verification. For QQ Mail, enable SMTP in QQ Mail settings
# and use the generated authorization code, not your QQ login password.
MAIL_ENABLED=false
MAIL_PROVIDER=qq
MAIL_SMTP_HOST=smtp.qq.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SSL=true
MAIL_SMTP_STARTTLS=false
MAIL_SMTP_USER=your@qq.com
MAIL_SMTP_PASSWORD=your_qq_mail_authorization_code
MAIL_FROM=your@qq.com
MAIL_FROM_NAME=CausalGraph AI
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_RESEND_COOLDOWN_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_CODE_LENGTH=6

# Vector store provider: local | pinecone
VECTOR_STORE_PROVIDER=local

# Long-term user memory vectors. Defaults inherit VECTOR_STORE_PROVIDER.
# Keep this enabled so durable preferences are semantically retrievable.
USER_MEMORY_VECTOR_ENABLED=true
USER_MEMORY_VECTOR_PROVIDER=local
USER_MEMORY_VECTOR_NAMESPACE=esg-demo-memory
USER_MEMORY_VECTOR_DIR=./data/vector_store/user_memories

# Pinecone configuration
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=esg-demo
# If you use bge-m3, create the Pinecone dense index with dimension 1024 and cosine metric.
PINECONE_METRIC=cosine

# Neo4j configuration
# Local docker-compose defaults: bolt://localhost:7687 / neo4j / neo4j123
# Use the full Neo4j Aura connection URI from the ESG instance connection panel.
# The instance display name (for example, "ESG") is not a resolvable host.
# Example shape: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# Set this to the actual database name inside the instance. If the database is named ESG, use ESG.
NEO4J_DATABASE=ESG
NEO4J_AUTO_SYNC=true
